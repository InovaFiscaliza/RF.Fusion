FROM docker.io/library/python:3.11-slim

# ======================================================================
# RF.Fusion Web Container
# Zabbix -> Web UI (Flask) -> MariaDB (HOST_TASK) -> appCataloga
# ======================================================================

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1

# -------------------------------------------------
# Utilitários essenciais + SSH
# -------------------------------------------------
RUN apt-get update && apt-get install -y --no-install-recommends \
    openssh-server \
    net-tools \
    iputils-ping \
    iproute2 \
    dnsutils \
    netcat-openbsd \
    procps \
    curl \
    vim \
    less \
    ca-certificates \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# -------------------------------------------------
# Dependências Python (Web + SQL)
# -------------------------------------------------
RUN pip install --no-cache-dir \
    flask \
    waitress \
    requests \
    mysql-connector-python

# -------------------------------------------------
# Diretórios RF.Fusion
# -------------------------------------------------
RUN mkdir -p \
    /var/run/sshd \
    /RF.Fusion \
    /opt/rffusion/bin

# -------------------------------------------------
# Configuração mínima de SSH
# (mantenha apenas se realmente precisar)
# -------------------------------------------------
RUN sed -i 's/#PermitRootLogin prohibit-password/PermitRootLogin yes/' /etc/ssh/sshd_config \
 && sed -i 's/#PasswordAuthentication yes/PasswordAuthentication yes/' /etc/ssh/sshd_config

# -------------------------------------------------
# Entrypoint
# -------------------------------------------------
COPY docker-entrypoint.sh /usr/local/bin/docker-entrypoint.sh
RUN chmod +x /usr/local/bin/docker-entrypoint.sh

EXPOSE 22 9082

ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]

# ============================================================================
# Containerfile - Debian 12 Python (RF.Fusion)
# ============================================================================
FROM debian:12

ENV DEBIAN_FRONTEND=noninteractive
ENV CONDA_DIR=/opt/conda
ENV PATH=$CONDA_DIR/bin:$PATH

# ============================================================================
# 1️⃣ Instala pacotes básicos e utilitários
# ============================================================================
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        curl wget git bash bzip2 ca-certificates \
        openssh-server iputils-ping net-tools \
        libglib2.0-0 libxext6 libsm6 libxrender1 && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# ============================================================================
# 2️⃣ Instala o Miniconda
# ============================================================================
RUN curl -sLo ~/miniconda.sh https://repo.anaconda.com/miniconda/Miniconda3-latest-Linux-x86_64.sh && \
    bash ~/miniconda.sh -b -p $CONDA_DIR && \
    rm ~/miniconda.sh && \
    $CONDA_DIR/bin/conda clean -afy

# ============================================================================
# 3️⃣ Aceita Termos de Serviço da Anaconda
# ============================================================================
RUN $CONDA_DIR/bin/conda tos accept --override-channels --channel https://repo.anaconda.com/pkgs/main && \
    $CONDA_DIR/bin/conda tos accept --override-channels --channel https://repo.anaconda.com/pkgs/r

# ============================================================================
# 4️⃣ Configura canais Conda
# ============================================================================
RUN $CONDA_DIR/bin/conda config --remove channels intel || true && \
    $CONDA_DIR/bin/conda config --add channels conda-forge && \
    $CONDA_DIR/bin/conda config --add channels defaults && \
    echo "✅ Intel channel removed from Conda config."

# ============================================================================
# 5️⃣ Define diretório de trabalho e copia arquivos
# ============================================================================
WORKDIR /app
COPY environment.yml /tmp/environment.yml
COPY docker-entrypoint.sh /usr/local/bin/entrypoint.sh

# ============================================================================
# 6️⃣ Remove canal 'intel' diretamente do environment.yml
# ============================================================================
RUN set -eux; \
    echo "🧹 Cleaning environment.yml (removing intel channel)..."; \
    sed -i '/- intel/d' /tmp/environment.yml; \
    echo "✅ Cleaned environment.yml:"; \
    grep -A3 channels /tmp/environment.yml || true

# ============================================================================
# 7️⃣ Cria o ambiente Conda
# ============================================================================
RUN set -eux; \
    sed -i 's/\r$//g' /usr/local/bin/entrypoint.sh; \
    chmod +x /usr/local/bin/entrypoint.sh; \
    echo "📦 Creating Conda environment from environment.yml..."; \
    if [ -f /tmp/environment.yml ]; then \
        $CONDA_DIR/bin/conda env create -f /tmp/environment.yml || \
        $CONDA_DIR/bin/conda env update -f /tmp/environment.yml || \
        { echo "❌ Conda environment creation failed"; exit 1; }; \
    else \
        echo "⚠️  environment.yml not found, skipping Conda env creation"; \
    fi; \
    echo "✅ Conda environment created successfully"; \
    $CONDA_DIR/bin/conda clean -afy

# ============================================================================
# 8️⃣ Configura SSH e usuário root
# ============================================================================
RUN mkdir -p /var/run/sshd && chmod 755 /var/run/sshd && \
    echo "root:changeme" | chpasswd && \
    sed -i 's/^#\?PermitRootLogin.*/PermitRootLogin yes/' /etc/ssh/sshd_config && \
    sed -i 's/^#\?PasswordAuthentication.*/PasswordAuthentication yes/' /etc/ssh/sshd_config

# ============================================================================
# 9️⃣ Expõe portas padrão
# ============================================================================
EXPOSE 22 5555

# ============================================================================
# 🔟 Entrypoint e execução
# ============================================================================
ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
CMD ["/usr/sbin/sshd", "-D"]
